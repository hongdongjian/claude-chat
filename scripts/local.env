# claude-chat local dev environment overrides.
# scripts/dev.sh sources this file before launching server/web, so every
# variable here is exported for the child processes.
# Lines starting with # are comments. Shell quoting rules apply.

############################
# Server: HTTP / WebSocket
############################
PORT=3000
HOST=127.0.0.1
# Set NODE_ENV=production to emit JSON logs and disable pino-pretty.
# NODE_ENV=development

############################
# Server: storage
############################
# Per-session workspace root (each session gets its own subdir here).
# CHAT_WORKSPACES_ROOT="$HOME/.claude-chat/workspaces"
# SQLite metadata DB.
# CHAT_DB_PATH="$HOME/.claude-chat/db.sqlite"
# Auto git init each new workspace dir (default: false).
# CHAT_AUTO_GIT_INIT=false
# Max bytes allowed for a single writeTextFile call (default 5 MiB).
# CHAT_MAX_WRITE_SIZE=5242880

############################
# Claude Code CLI bridge
############################
# Explicit path to the claude binary. Leave unset to auto-detect.
# CLAUDE_CODE_EXECUTABLE=/usr/local/bin/claude
# Auto-approve every tool permission request (DANGEROUS).
# "1"/"true" = auto-allow, "0"/"false" = interactive prompts in the UI.
CLAUDE_CHAT_AUTO_ALLOW_ALL=1

############################
# Claude model overrides
############################
MODEL_NAME=gpt-5-mini
# MODEL_NAME=claude-sonnet-4.6
ANTHROPIC_MODEL=$MODEL_NAME
ANTHROPIC_DEFAULT_HAIKU_MODEL=$MODEL_NAME
ANTHROPIC_DEFAULT_SONNET_MODEL=$MODEL_NAME
ANTHROPIC_DEFAULT_OPUS_MODEL=$MODEL_NAME

############################
# Logging (pino)
############################
LOG_LEVEL=info
# Enable file sink + rotation. Parent dirs will be created automatically.
# LOG_FILE=.run/logs/server.log
# LOG_ROTATE_FREQUENCY=daily   # daily | hourly | <ms>
# LOG_ROTATE_SIZE=20m
# LOG_ROTATE_MAX=14

############################
# Frontend (Vite dev server)
############################
WEB_PORT=5173
